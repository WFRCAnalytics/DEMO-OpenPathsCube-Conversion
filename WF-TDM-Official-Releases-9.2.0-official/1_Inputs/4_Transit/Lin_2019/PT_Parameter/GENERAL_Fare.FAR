;define fare systems
    FARESYSTEM,
           NUMBER     = 1, 
           LONGNAME   = 'Regular Fare Service',   ;up to 40 characters
           NAME       = 'RegularFare',            ;up to 14 characters
           STRUCTURE  = 'FLAT',                   ;FLAT, DISTANCE, HILOW, COUNT, FROMTO, ACCUMULATE, FREE
               SAME   = 'CUMULATIVE',             ;SEPARATE, CUMULATIVE (default), use CUMULATIVE for STRUCTURE=FLAT, use SEPARATE for STRUCTURE=DISTANCE (SEPARATE calculates fare for each leg separately)
           IBOARDFARE = 250,                      ;need to be in consistent units with value of time in mode choice
           FAREFROMFS = 0, 0, 0, 250              ;additional fare from transferig from fare systems 1,2,3 to fare system 1

    FARESYSTEM,
           NUMBER     = 2, 
           LONGNAME   = 'Premium Fare Service', 
           NAME       = 'PremiumFare', 
           STRUCTURE  = 'FLAT',  
               SAME   = 'CUMULATIVE',
           IBOARDFARE = 550, 
           FAREFROMFS = 300, 0, 0, 550            ;transfer from fare systems 1,2,3 to fare system 2

    FARESYSTEM,
           NUMBER     = 3, 
           LONGNAME   = 'CRT Fare', 
           NAME       = 'CRTFare', 
           STRUCTURE  = 'COUNT',  
               SAME   = 'CUMULATIVE',
           FAREZONES  = ni.CRTFAREZN,             ;node field containing fare zone number
           FARETABLE  =  1-250,                   ;fare applied for number of unique FAREZONES crossed
                         2-310,
                         3-370,
                         4-430,
                         5-490,
                         6-550,
                         7-610,
                         8-670,
                         9-730,
                        10-790,
                        11-850,
                        12-910,
                        13-970,
                        14-1030,
           FAREFROMFS = 0, 0, 0, 0                ;transfer from fare systems 1,2,3 to fare system 3

    FARESYSTEM,
           NUMBER     = 4, 
           LONGNAME   = 'Free Fare Service', 
           NAME       = 'FreeFare', 
           STRUCTURE  = 'FLAT',  
               SAME   = 'CUMULATIVE',
           IBOARDFARE = 0.01, 
           FAREFROMFS = 0, 0, 0, 0                ;transfer from fare systems 1,2,3 to fare system 2