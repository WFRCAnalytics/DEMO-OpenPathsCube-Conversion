;HBW_Output_Logsums.block

IF (VEH==1 & INC==1 & ACCESS==1)
  sum_EU = EU_motor + EU_nonmotor
  IF (sum_EU=0)
    veh0_low_walk_log[j]=-99
  ELSE
    veh0_low_walk_log[j] = ln(sum_EU + .000000001)
  ENDIF

ELSEIF (VEH==1 & INC==1 & ACCESS==2)
  sum_EU = EU_motor + EU_nonmotor
  IF (sum_EU=0)
    veh0_low_drive_log[j]=-99
