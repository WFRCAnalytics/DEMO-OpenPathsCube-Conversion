IF (VEH==1 & INC==1 & ACCESS==1)

  veh0_low_walk_nmshare[j] = prob_nonmotor
  veh0_low_walk_nmlog[j] = logsum_nonmotor
  veh0_low_walk_motlog[j] = logsum_motor
  
 ELSEIF (VEH==1 & INC==1 & ACCESS==2)

  veh0_low_drive_nmshare[j] = prob_nonmotor
  veh0_low_drive_nmlog[j] = logsum_nonmotor
  veh0_low_drive_motlog[j] = logsum_motor
  
 ELSEIF (VEH==1 & INC==1 & ACCESS==3)

  veh0_low_none_nmshare[j] = prob_nonmotor
  veh0_low_none_nmlog[j] = logsum_nonmotor
  veh0_low_none_motlog[j] = logsum_motor  
  
ELSEIF (VEH==1 & INC==2 & ACCESS==1)

  veh0_high_walk_nmshare[j] = prob_nonmotor
  veh0_high_walk_nmlog[j] = logsum_nonmotor
