                veh_P_NHB_SR_NON       = P_NHB_SR_NON       / @VehOcc_2p_NHB@
                veh_P_NHB_SR_HOV       = P_NHB_SR_HOV       / @VehOcc_2p_NHB@
                veh_P_NHB_DA_TOL       = P_NHB_DA_TOL       / @VehOcc_NHB@
                veh_P_NHB_SR_TOL       = P_NHB_SR_TOL       / @VehOcc_2p_NHB@
                veh_P_HBC_DA_NON       = P_HBC_DA_NON       / @VehOcc_HBC@
                veh_P_HBC_SR_NON       = P_HBC_SR_NON       / @VehOcc_2p_HBC@
                veh_P_HBC_SR_HOV       = P_HBC_SR_HOV       / @VehOcc_2p_HBC@
                veh_P_HBC_DA_TOL       = P_HBC_DA_TOL       / @VehOcc_HBC@
                veh_P_HBC_SR_TOL       = P_HBC_SR_TOL       / @VehOcc_2p_HBC@
                veh_P_HBS_DriveSelf_Pr = P_HBS_DriveSelf_Pr / @VehOcc_HBSch@
                veh_P_HBS_DriveSelf_Sc = P_HBS_DriveSelf_Sc / @VehOcc_HBSch@
                veh_P_HBS_DropOff_Pr   = P_HBS_DropOff_Pr   / @VehOcc_HBSch@
                veh_P_HBS_DropOff_Sc   = P_HBS_DropOff_Sc   / @VehOcc_HBSch@
                veh_P_SchoolBus_Pr     = P_SchoolBus_Pr     / @Schoolbus_VO@
                veh_P_SchoolBus_Sc     = P_SchoolBus_Sc     / @Schoolbus_VO@
                
                veh_A_HBW_DA_NON       = A_HBW_DA_NON       / @VehOcc_HBW@
                veh_A_HBW_SR_NON       = A_HBW_SR_NON       / @VehOcc_2p_HBW@
                veh_A_HBW_SR_HOV       = A_HBW_SR_HOV       / @VehOcc_2p_HBW@
                veh_A_HBW_DA_TOL       = A_HBW_DA_TOL       / @VehOcc_HBW@
                veh_A_HBW_SR_TOL       = A_HBW_SR_TOL       / @VehOcc_2p_HBW@
                veh_A_HBO_DA_NON       = A_HBO_DA_NON       / @VehOcc_HBO@
                veh_A_HBO_SR_NON       = A_HBO_SR_NON       / @VehOcc_2p_HBO@
                veh_A_HBO_SR_HOV       = A_HBO_SR_HOV       / @VehOcc_2p_HBO@
                veh_A_HBO_DA_TOL       = A_HBO_DA_TOL       / @VehOcc_HBO@
                veh_A_HBO_SR_TOL       = A_HBO_SR_TOL       / @VehOcc_2p_HBO@
                veh_A_NHB_DA_NON       = A_NHB_DA_NON       / @VehOcc_NHB@
                veh_A_NHB_SR_NON       = A_NHB_SR_NON       / @VehOcc_2p_NHB@
                veh_A_NHB_SR_HOV       = A_NHB_SR_HOV       / @VehOcc_2p_NHB@
                veh_A_NHB_DA_TOL       = A_NHB_DA_TOL       / @VehOcc_NHB@
                veh_A_NHB_SR_TOL       = A_NHB_SR_TOL       / @VehOcc_2p_NHB@
                veh_A_HBC_DA_NON       = A_HBC_DA_NON       / @VehOcc_HBC@
                veh_A_HBC_SR_NON       = A_HBC_SR_NON       / @VehOcc_2p_HBC@
                veh_A_HBC_SR_HOV       = A_HBC_SR_HOV       / @VehOcc_2p_HBC@
                veh_A_HBC_DA_TOL       = A_HBC_DA_TOL       / @VehOcc_HBC@
                veh_A_HBC_SR_TOL       = A_HBC_SR_TOL       / @VehOcc_2p_HBC@
                veh_A_HBS_DriveSelf_Pr = A_HBS_DriveSelf_Pr / @VehOcc_HBSch@
                veh_A_HBS_DriveSelf_Sc = A_HBS_DriveSelf_Sc / @VehOcc_HBSch@
                veh_A_HBS_DropOff_Pr   = A_HBS_DropOff_Pr   / @VehOcc_HBSch@
                veh_A_HBS_DropOff_Sc   = A_HBS_DropOff_Sc   / @VehOcc_HBSch@
                veh_A_SchoolBus_Pr     = A_SchoolBus_Pr     / @Schoolbus_VO@
                veh_A_SchoolBus_Sc     = A_SchoolBus_Sc     / @Schoolbus_VO@
                
                
                ;total vehicle level metrics and print them to output csv
                Metric = 'VHD'
                READ FILE = '@ParentDir@2_ModelScripts\5_AssignHwy\block\09_total_vehicles.block'
                READ FILE = '@ParentDir@2_ModelScripts\5_AssignHwy\block\09_print_vehicles.block'
                
            endif  ;(@NumMetrics@=3)
            
            
