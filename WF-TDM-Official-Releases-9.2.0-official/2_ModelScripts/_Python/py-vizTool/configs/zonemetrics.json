{
    "outputFileName": "j-zone-metrics.json",
    "idCol": "TAZID",
    "groupAndSum": true,
    "filters": [
        {   "filterCode": "fTod4",
            "filterDescription": "Time of day",
            "filterLocation": "long",
            "tdmCsvColumn": "Period"
        },
        {   "filterCode": "fPurp12",
            "filterDescription": "Trip Purpose",
            "filterLocation": "long",
            "tdmCsvColumn": "Purpose"
        },
        {   "filterCode": "fPA",
